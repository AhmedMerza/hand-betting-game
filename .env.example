APP_NAME="Hand Betting Game"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

# Using FILE driver for zero-config portability for the reviewer
SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# SQLite Configuration (Recommended for local review)
DB_CONNECTION=sqlite

# Standard Inertia configuration
VITE_APP_NAME="${APP_NAME}"
